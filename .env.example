# --- OpenAI ---
OPENAI_API_KEY=sk-...

# Model for the orchestrator + digest-writer (reasoning-heavy, low call volume)
ORCHESTRATOR_MODEL=gpt-5.6-terra

# Model for the linkedin-scanner subagent + the underlying browser-use loop
# (high call volume). Defaults to ORCHESTRATOR_MODEL if unset - override with
# a cheaper tier (e.g. gpt-5.6-luna) if you want to tune cost vs. quality.
# BROWSER_SCAN_MODEL=gpt-5.6-luna

# --- LinkedIn ---
# Only ever read into browser-use's sensitive_data mechanism, never placed
# directly into a prompt string. See src/linkedin_ai_agent/browser_tool.py.
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=your-password

# Set to "false" to watch the browser window instead of running headless
BROWSER_USE_HEADLESS=true

# --- LangSmith (optional, but recommended - see README "Observability") ---
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=linkedin-ai-digest
